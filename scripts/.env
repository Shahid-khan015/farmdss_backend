# Copy to `backend/scripts/.env` OR rely on `backend/.env` (loaded automatically).
# Run from `backend/`:  python scripts/mock_iot_simulator.py --dry-run

# Must match FastAPI (see backend/.env)
DATABASE_URL=postgresql://postgres:P%40ssw0rd@localhost:5432/tractor_dss
# Simulator-only (optional overrides)
IOT_SIMULATOR_MODE=mock
IOT_SIMULATOR_INTERVAL_SEC=5
IOT_SIMULATOR_CYCLES=10
IOT_DEFAULT_DEVICE_ID=default
IOT_HTTP_POLL_LIMIT=5

# Adafruit mode
AIO_USERNAME=
AIO_KEY=

# Optional: verify after ingest
BACKEND_BASE_URL=http://localhost:8000
IOT_VERIFY_LATEST=1
ACCESS_TOKEN=

DRY_RUN=0
